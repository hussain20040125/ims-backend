{
  "name": "ims-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "echo 'No build step required'",
    "start": "NODE_ENV=production node src/server.js",
    "dev": "nodemon --watch src --ext js,json --exec node src/server.js",
    "dev:dev": "nodemon --watch src --ext js,json --exec \"node src/server.js --env=development\"",
    "dev:prod": "nodemon --watch src --ext js,json --exec \"node src/server.js --env=production\"",
    "dev:uat": "nodemon --watch src --ext js,json --exec \"node src/server.js --env=uat\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.8",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
